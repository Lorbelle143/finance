# ── Local development ─────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
PORT=4000
JWT_SECRET="change-me-to-a-long-random-secret"
NODE_ENV="development"

# ── Production (Vercel + Neon PostgreSQL) ─────────────────────────────────────
# Get these from your Neon dashboard → Connection Details
# DATABASE_URL  = pooled connection  (for Prisma queries)
# DIRECT_URL    = direct connection  (for Prisma migrations)

# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
# JWT_SECRET="a-very-long-random-secret-min-32-chars"
# NODE_ENV="production"
# FRONTEND_URL="https://your-frontend.vercel.app"
